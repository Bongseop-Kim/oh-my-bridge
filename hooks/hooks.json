{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-interceptor.sh",
            "timeout": 180,
            "statusMessage": "Routing to Codex CLI..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_oh-my-bridge_codex__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-codex-usage.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-fallback.sh"
          }
        ]
      }
    ]
  }
}
